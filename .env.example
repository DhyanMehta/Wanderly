# LLM Provider API Keys
# Choose either Groq or OpenAI (or both) for your LLM provider

# Groq API Key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Weather Information API Key
# Get from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweather_api_key_here

# Google Places API Key
# Get from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API
GPLACES_API_KEY=your_google_places_api_key_here

# Currency Exchange Rate API Key
# Get from: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Tavily Search API Key (Used as fallback for place search)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Alpha Vantage API Key (Optional - used in arithmetic operations)
# Get from: https://www.alphavantage.co/
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
